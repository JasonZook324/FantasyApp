@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="en" class="">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FantasyApp</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/theme.css" />
    @RenderSection("Head", required: false)
    <script src="~/js/theme.js"></script>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm border-bottom box-shadow mb-3">
            <div class="container d-flex align-items-center">
                <a class="navbar-brand" asp-page="/Index">FantasyApp</a>
                <div class="ms-auto d-flex gap-2 align-items-center">
                    <a class="nav-link" asp-page="/Index">Home</a>

                    @{
                        var username = Context?.Session?.GetString("Username");
                        if (string.IsNullOrEmpty(username))
                        {
                            <a class="btn btn-secondary btn-sm" asp-page="/Login">Login</a>
                        }
                        else
                        {
                            <span class="mx-2">Hello, @username</span>
                            <form class="d-inline" method="post" asp-page="/Login" asp-page-handler="Logout">
                                <button type="submit" class="btn btn-secondary btn-sm">Logout</button>
                            </form>
                        }
                    }

                    <button class="btn btn-secondary btn-sm" type="button" id="theme-toggle">Toggle theme</button>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
</body>
</html>
