@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="en" class="">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FantasyApp</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/theme.css" />
    @RenderSection("Head", required: false)
    <script src="~/js/theme.js"></script>
</head>
<body>
    <div class="app-shell">
        <aside class="sidebar">
            <div class="brand">
                <span class="dot"></span>
                <div>
                    <div>ESPN Fantasy</div>
                    <small class="text-muted">API Manager</small>
                </div>
            </div>
            <div class="spacer"></div>
            <div class="section">Main</div>
            <ul class="nav">
                <li><a class="@(Context.Request.Path.StartsWithSegments("/Index") ? "active" : null)" asp-page="/Index"><span class="icon">??</span> Home</a></li>
                <li><a class="@(Context.Request.Path.StartsWithSegments("/EspnAuth") ? "active" : null)" asp-page="/EspnAuth"><span class="icon">??</span> Fantasy Manager</a></li>
            </ul>
            <div class="section">League</div>
            <ul class="nav">
                <li><button disabled><span class="icon">??</span> Standings</button></li>
                <li><button disabled><span class="icon">??</span> Team Rosters</button></li>
                <li><button disabled><span class="icon">??</span> Matchups</button></li>
                <li><button disabled><span class="icon">??</span> Player Details</button></li>
                <li><button disabled><span class="icon">??</span> AI Recommendations</button></li>
                <li><button disabled><span class="icon">??</span> Trade Analyzer</button></li>
                <li><button disabled><span class="icon">??</span> Prompt Builder</button></li>
            </ul>
            <div class="spacer"></div>
            <div class="section">Account</div>
            <ul class="nav">
                @{
                    var username = Context?.Session?.GetString("Username");
                }
                @if (string.IsNullOrEmpty(username))
                {
                    <li><a asp-page="/Login"><span class="icon">??</span> Login</a></li>
                }
                else
                {
                    <li><span class="d-flex align-items-center gap-2"><span class="icon">?????</span> Hello, @username</span></li>
                    <li>
                        <form method="post" asp-page="/Login" asp-page-handler="Logout">
                            <button class="btn btn-secondary w-100" type="submit">Logout</button>
                        </form>
                    </li>
                }
                <li><button id="theme-toggle" class="btn btn-secondary w-100 mt-2" type="button">Toggle theme</button></li>
            </ul>
        </aside>

        <div class="content-area">
            <header>
                @{ 
                    var loggedIn = Context?.Session?.GetInt32("UserId") != null; 
                    var leagueName = Context?.Session?.GetString("leagueName");
                    var hasLeague = !string.IsNullOrWhiteSpace(leagueName);
                    if (loggedIn && !hasLeague)
                    {
                        <div class="auth-banner-wrap">
                            <div class="container">
                                <div class="auth-banner d-flex align-items-center justify-content-between">
                                    <div class="d-flex align-items-start gap-3">
                                        <div class="auth-icon">&#9888;</div>
                                        <div>
                                            <div class="auth-title">No League Connected</div>
                                            <div class="auth-sub">Configure your ESPN credentials to get started</div>
                                        </div>
                                    </div>
                                    <a class="btn btn-banner" asp-page="/EspnAuth">
                                        <span class="me-2">&#9881;</span>Setup Authentication
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                    else if (loggedIn && hasLeague)
                    {
                        var seasonId = Context?.Session?.GetInt32("seasonId");
                        var leagueSize = Context?.Session?.GetInt32("leagueSize");
                        var sp = Context?.Session?.GetInt32("scoringPeriodId");
                        <div class="league-banner-wrap">
                            <div class="container">
                                <div class="league-banner d-flex align-items-center justify-content-between">
                                    <div>
                                        <div class="title d-flex align-items-center gap-2">
                                            <span>?? @leagueName</span>
                                            <span class="badge rounded-pill" style="background:#064e3b;color:#bbf7d0;border:1px solid #065f46">FFL</span>
                                        </div>
                                        <div class="meta mt-1 small">
                                            Season @seasonId Ģ @leagueSize teams Ģ Week @sp
                                        </div>
                                    </div>
                                    <div class="d-flex gap-2">
                                        <form method="post" asp-page="/EspnAuth" asp-page-handler="Refresh">
                                            <button class="btn btn-league" type="submit">? Refresh Data</button>
                                        </form>
                                        <form method="post" asp-page="/EspnAuth" asp-page-handler="Disconnect">
                                            <button class="btn btn-league" type="submit">? Disconnect</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </header>
            <div class="container">
                <main role="main" class="pb-3">
                    @RenderBody()
                </main>
            </div>
        </div>
    </div>
</body>
</html>
