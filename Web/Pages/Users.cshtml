@page
@model Web.Pages.UsersModel
@{
    ViewData["Title"] = "Users";
}
<h2>Users</h2>
@if (Model.Error is not null)
{
    <div class="alert alert-danger">@Model.Error</div>
}
@if (Model.Users?.Count > 0)
{
    <table class="table table-striped">
        <thead>
            <tr><th>Id</th><th>Username</th><th>Active</th><th>RoleId</th></tr>
        </thead>
        <tbody>
        @foreach (var u in Model.Users)
        {
            <tr>
                <td>@u.Id</td>
                <td>@u.Username</td>
                <td>@u.IsActive</td>
                <td>@u.RoleId</td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <p>No users found.</p>
}
